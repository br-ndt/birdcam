[Unit]
Description=Bird feeder cam (capture + viewer backend + stream)
After=network-online.target sound.target
Wants=network-online.target

[Service]
Type=simple
User=yourUser
WorkingDirectory=/path/to/birdcam
EnvironmentFile=/etc/birdcam/env
ExecStart=/path/to/birdcam/.venv/bin/python /path/to/birdcam/birdcam.py
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
